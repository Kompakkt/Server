    "elysia-prometheus": "^1.0.0",
    "jose": "^6.1.3",
    "ky": "^1.14.3",
    "mongodb": "7.0.0",
    "nodemailer": "^7.0.12",
    "object-hash": "^3.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rotating-file-stream": "^3.2.7",
