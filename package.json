  },
  "homepage": "https://github.com/Kompakkt/Server#readme",
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/server-timing": "^1.4.0",
    "@elysiajs/static": "^1.4.7",
    "@kompakkt/common": "git+https://github.com/Kompakkt/Common#07dd559f75ae4e44adebe786c39b2343740df5ab",
    "@react-email/components": "^1.0.6",
    "@react-email/preview-server": "^5.2.5",
    "@react-email/render": "^2.0.4",
    "@tailwindcss/cli": "^4.1.18",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "arktype": "^2.1.29",
    "blurhash": "^2.0.5",
